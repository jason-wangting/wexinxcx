page {
  background: #eef5ef;
}

.page {
  padding: 24rpx;
  font-family: PingFang SC;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}

/* ===== 未登录 ===== */
.login-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 60rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-top: 40rpx;
}

.login-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  margin-bottom: 28rpx;
  background: #eee;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 12rpx;
}

.login-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.login-wx-btn {
  width: 100%;
  background: #1aad19;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  padding: 0;
  height: 88rpx;
  line-height: 88rpx;
}

/* ===== 确认昵称 ===== */
.nickname-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 60rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-top: 40rpx;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  margin-bottom: 32rpx;
}

.nickname-hint {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.nickname-input {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  text-align: center;
  width: 100%;
  margin-bottom: 32rpx;
}

.confirm-btn {
  width: 100%;
  background: #1f9d3a;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
}

/* ===== 已登录 ===== */
.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.profile-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-height: 88rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: block;
  margin-right: 16rpx;
}

.user-name {
  font-size: 32rpx;
  color: #111;
  font-weight: 600;
  line-height: 1.3;
}

.member-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 30rpx;
  background: #e8f5e9;
  color: #1f7f34;
  font-size: 22rpx;
}

.role-pick-card {
  padding-top: 30rpx;
  padding-bottom: 30rpx;
}

.role-pick-title {
  font-size: 32rpx;
  color: #222;
  font-weight: 600;
}

.role-pick-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #888;
}

.role-pick-actions {
  margin-top: 26rpx;
  display: flex;
  gap: 14rpx;
}

.role-btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.role-btn.seller {
  color: #fff;
  background: #1f9d3a;
}

.role-btn.buyer {
  color: #2457c5;
  background: #eef3ff;
}

.role-switch-card {
  padding-top: 12rpx;
}

.role-switch-row {
  align-items: center;
}

.role-switch-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.role-chip {
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #666;
  background: #f0f0f0;
}

.role-chip.active {
  color: #fff;
  background: #1f9d3a;
}

.arrow {
  width: 28rpx;
  height: 88rpx;
  margin-left: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #bbb;
  line-height: 1;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ededed;
}

.row:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.logout-label {
  color: #cc4d33;
  width: 100%;
  text-align: center;
}
