page {
  background: #f3f7f3;
}

.page {
  padding: 24rpx;
  font-family: PingFang SC;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f1f1f;
  margin-bottom: 20rpx;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.input {
  background: #f6f6f6;
  border-radius: 10rpx;
  padding: 18rpx;
  font-size: 28rpx;
}

.action-row {
  margin-top: 8rpx;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.primary {
  background: #1f9d3a;
  color: #fff;
}

.empty {
  font-size: 26rpx;
  color: #888;
  padding: 24rpx 0;
}

.goods-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ededed;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-name {
  font-size: 30rpx;
  color: #111;
  font-weight: 500;
}

.goods-meta {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #5f5f5f;
}

.item-actions {
  display: flex;
  gap: 20rpx;
}

.text-btn {
  color: #1f9d3a;
  font-size: 26rpx;
}

.text-btn.danger {
  color: #cc4d33;
}
