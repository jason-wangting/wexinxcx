<view class="page">
  <view class="card invite-card">
    <view class="card-title">微信邀请绑定</view>
    <view class="invite-desc">生成邀请后转发给客户，对方点开小程序可一键绑定为买家。</view>
    <view class="action-row">
      <button class="btn primary" bindtap="createInvite">生成邀请</button>
      <button class="btn" open-type="share" disabled="{{!invitePath}}">分享邀请</button>
    </view>
    <view wx:if="{{invitePath}}" class="invite-path">已生成：{{invitePath}}</view>
    <button wx:if="{{invitePath}}" class="mini-btn" bindtap="copyInvitePath">复制邀请路径</button>
  </view>

  <view class="card form-card">
    <view class="card-title">{{editId ? '编辑客户' : '新增客户'}}</view>

    <view class="field">
      <view class="label">客户名称</view>
      <input class="input" placeholder="例如：王老板" value="{{formName}}" bindinput="onNameInput" />
    </view>

    <view class="field">
      <view class="label">联系电话（可选）</view>
      <input class="input" type="number" placeholder="例如：13800000000" value="{{formPhone}}" bindinput="onPhoneInput" />
    </view>

    <view class="action-row">
      <button class="btn primary" bindtap="submitCustomer">{{editId ? '保存修改' : '添加客户'}}</button>
      <button class="btn" bindtap="resetForm">清空</button>
    </view>
  </view>

  <view class="card list-card">
    <view class="card-title">客户列表</view>

    <view wx:if="{{!customerList.length}}" class="empty">暂无客户，请先添加</view>

    <view wx:for="{{customerList}}" wx:key="id" class="customer-item">
      <view>
        <view class="customer-name">{{item.name}}</view>
        <view wx:if="{{item.phone}}" class="customer-phone">{{item.phone}}</view>
        <view wx:if="{{item.source === 'wechat_invite'}}" class="source-tag">微信绑定</view>
      </view>
      <view wx:if="{{item.source !== 'wechat_invite'}}" class="item-actions">
        <text class="text-btn" data-id="{{item.id}}" bindtap="onEditCustomer">编辑</text>
        <text class="text-btn danger" data-id="{{item.id}}" bindtap="onDeleteCustomer">删除</text>
      </view>
    </view>
  </view>
</view>
